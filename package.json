{
  "name": "smart-link-api",
  "version": "1.0.0",
  "description": "Smart URL shortening and link management API",
  "main": "dist/server.js",
  "scripts": {
    "dev": "tsx watch src/server.ts",
    "build": "tsup src/server.ts src/jobs/weekly-analytics-report.ts src/jobs/retry-notification-deliveries.ts src/jobs/cleanup-guest-links.ts --format esm --out-dir dist",
    "start": "node dist/server.js",
    "job:weekly-analytics": "tsx src/jobs/weekly-analytics-report.ts",
    "job:weekly-analytics:start": "node dist/jobs/weekly-analytics-report.js",
    "job:retry-notifications": "tsx src/jobs/retry-notification-deliveries.ts",
    "job:retry-notifications:start": "node dist/jobs/retry-notification-deliveries.js",
    "job:cleanup-guest-links": "tsx src/jobs/cleanup-guest-links.ts",
    "job:cleanup-guest-links:start": "node dist/jobs/cleanup-guest-links.js"
  },
  "keywords": [],
  "author": "Suvra Deb Paul",
  "license": "ISC",
  "type": "module",
  "dependencies": {
    "@better-auth/mongo-adapter": "^1.6.11",
    "bcrypt": "^6.0.0",
    "better-auth": "^1.6.11",
    "cors": "^2.8.6",
    "dotenv": "^17.4.2",
    "express": "^5.2.1",
    "express-rate-limit": "^8.5.2",
    "helmet": "^8.2.0",
    "jsonwebtoken": "^9.0.3",
    "mongodb": "^7.2.0",
    "mongoose": "^9.6.2",
    "morgan": "^1.10.1",
    "nanoid": "^5.1.11",
    "qrcode": "^1.5.4",
    "stripe": "^22.2.0",
    "ua-parser-js": "^2.0.10",
    "zod": "^4.4.3"
  },
  "devDependencies": {
    "@types/bcrypt": "^6.0.0",
    "@types/cors": "^2.8.19",
    "@types/express": "^5.0.6",
    "@types/jsonwebtoken": "^9.0.10",
    "@types/morgan": "^1.9.10",
    "@types/node": "^25.9.1",
    "@types/qrcode": "^1.5.6",
    "@types/ua-parser-js": "^0.7.39",
    "tsup": "^8.5.1",
    "tsx": "^4.22.3",
    "typescript": "^6.0.3"
  }
}
